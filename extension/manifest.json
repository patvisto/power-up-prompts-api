{
  "manifest_version": 3,
  "name": "Power Up Prompts",
  "version": "2.2.8",
  "description": "Power up your prompts into detailed, structured AI instructions.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Power Up Prompts",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "clipboardWrite",
    "alarms"
  ],
  "host_permissions": [
    "https://power-up-prompts-api.onrender.com/*"
  ]
}